#include <iostream>

int part(int mas[], int l, int r) {
    int a = mas[l];
    int i = l;
    int j = r - 1;
    while (i <= j) {
        while (mas[i] < a) i++;
        while (mas[j] > a) j--;
        if (i >= j) break;
        int temp = mas[i];
        mas[i] = mas[j];
        mas[j] = temp;
    }
    return j;
}

void fastSort(int mas[], int l, int r) {
    if (l >= r) return;
    int m = part(mas, l, r);
    fastSort(mas, l, m);
    fastSort(mas, m + 1, r);
}

int reversePart(int mas[], int l, int r) {
    int a = mas[l];
    int i = l;
    int j = r - 1;
    while (i <= j) {
        while (mas[i] > a) i++;
        while (mas[j] < a) j--;
        if (i >= j) break;
        int temp = mas[i];
        mas[i] = mas[j];
        mas[j] = temp;
    }
    return j;
}

void reverseFastSort(int mas[], int l, int r) {
    if (l >= r) return;
    int m = reversePart(mas, l, r);
    reverseFastSort(mas, l, m);
    reverseFastSort(mas, m + 1, r);
}

int oddEvenModifier(int x) {
    return x % 2 == 0 ? x : -x;
}

int oddEvenPart(int mas[], int l, int r) {
    int a = mas[l];
    int i = l;
    int j = r - 1;
    while (i <= j) {
        while (oddEvenModifier(mas[i]) < oddEvenModifier(a)) i++;
        while (oddEvenModifier(mas[j]) > oddEvenModifier(a)) j--;
        if (i >= j) break;
        int temp = mas[i];
        mas[i] = mas[j];
        mas[j] = temp;
    }
    return j;
}

void oddEvenFastSort(int mas[], int l, int r) {
    if (l >= r) return;
    int m = oddEvenPart(mas, l, r);
    oddEvenFastSort(mas, l, m);
    oddEvenFastSort(mas, m + 1, r);
}

void main() {
    int mas[] = { 2, 5, -8, 1, -4, 6, 3, -5, -9, 13, 0, 4, 9 };
    int n = sizeof(mas) / sizeof(int);
    int  i;
    for (i = 0; i < n; i++) {
        std::cout << mas[i] << " ";
    }
    std::cout << std::endl;
    std::cout << "Fast sort " << std::endl;
    fastSort(mas, 0, n);
    for (i = 0; i < n; i++) {
        std::cout << mas[i] << " ";
    }
    std::cout << std::endl;

    std::cout << "Reverse Fast sort " << std::endl;
    reverseFastSort(mas, 0, n);
    for (i = 0; i < n; i++) {
        std::cout << mas[i] << " ";
    }
    std::cout << std::endl;

    std::cout << "Odd even Fast sort " << std::endl;
    oddEvenFastSort(mas, 0, n);
    for (i = 0; i < n; i++) {
        std::cout << mas[i] << " ";
    }
    std::cout << std::endl;


    std::cout << "Fast sort full" << std::endl;
    fastSort(mas, 0, n);
    for (i = 0; i < n; i++) {
        std::cout << mas[i] << " ";
    }
    std::cout << std::endl;

    std::cout << "reverse fast sort from 2 to 10 " << std::endl;
    reverseFastSort(mas, 2, 10);
    for (i = 0; i < n; i++) {
        std::cout << mas[i] << " ";
    }
    std::cout << std::endl;

}
